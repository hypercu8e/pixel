{
  "name": "pixel-cleaner",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "containerEnv": {
    "PIP_DISABLE_PIP_VERSION_CHECK": "1",
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  },
  "remoteEnv": {
    "PATH": "/home/vscode/.venv/pixel/bin:${containerEnv:PATH}"
  },
  "postCreateCommand": "python -m venv /home/vscode/.venv/pixel && /home/vscode/.venv/pixel/bin/python -m pip install --upgrade pip && /home/vscode/.venv/pixel/bin/python -m pip install -e '.[dev]'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/home/vscode/.venv/pixel/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "tests"
        ]
      }
    }
  }
}
